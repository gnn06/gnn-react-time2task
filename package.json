{
  "name": "gnn-react-time2task",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://gnn06.github.io/gnn-react-time2task/",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@emotion/react": "^11.11.3",
    "@emotion/styled": "^11.11.0",
    "@fontsource/roboto": "^5.0.8",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@mui/x-date-pickers": "^9.0.4",
    "@reduxjs/toolkit": "^2.11.2",
    "@supabase/supabase-js": "^2.103.3",
    "color": "^4.2.3",
    "lodash": "^4.17.21",
    "material-react-table": "^3.2.1",
    "moment": "^2.30.1",
    "motion": "^12.4.7",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hotkeys-hook": "^4.6.1",
    "react-markdown": "^9.0.1",
    "react-redux": "^9.2.0",
    "react-resizable-panels": "^4.10.0",
    "react-router": "^7.14.1",
    "react-select": "^5.10.2"
  },
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "build:e2e": "tsc && vite build --mode test",
    "serve": "vite preview",
    "test": "vitest run",
    "test:data": "vitest run src/data src/utils",
    "test:ui": "vitest run src/components src/features src/hooks",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test",
    "test.coverage": "vitest run --coverage --watch=false",
    "eject": "react-scripts eject",
    "deploy": "gh-pages -d dist",
    "rclone-pull": "rclone copy --update --verbose onedriveperso:Documents/dev/time2task.tar.gz ../ && find . -mindepth 1 -maxdepth 1  ! -name node_modules -exec rm -rf {} + && tar xvf ../time2task.tar.gz && rm ../time2task.tar.gz",
    "rclone-push": "touch SYNC_FILE && tar cf ../time2task.tar.gz --exclude=node_modules  . &&  rclone move --update --progress ../time2task.tar.gz onedriveperso:Documents/dev/"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.10",
    "@types/node": "^20.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "gh-pages": "^6.1.1",
    "jsdom": "^24.1.1",
    "msw": "^2.3.4",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "undici": "^8.1.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
